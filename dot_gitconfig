[user]
	name = Michaël Fortin
	email = fortinmike@irradiated.net
[color]
	diff = auto
	status = auto
	branch = auto
[alias]
	logg = log --decorate --graph --oneline
	discard = reset --hard HEAD
	find = "!f() { git log --all -- **/$1*; }; f"
[init]
  defaultBranch = main
[core]
	quotepath = false
	attributesfile = ~/.gitattributes
	pager = delta
[branch]
	autosetuprebase = never
[push]
	default = simple
[gc]
	autoDetach = false
[format]
	pretty = oneline
[log]
	decorate = short
[diff "sketchtool"]
	textconv = sketchtool dump
	cachetextconv = true
	binary = true
[interactive]
	diffFilter = delta --color-only
[delta]
	file-decoration-style = none
	file-style = blue
	hunk-header-style = omit
	navigate = true
	line-numbers = true
	side-by-side = true
[pull]
	rebase = false
